# Copy this file to .env.local (for the frontend) and .env (for serverless functions)
# Vercel will inject these values via project environment variables.

# Google Gemini API Key used by /api/gemini
GEMINI_API_KEY=""

# Postgres connection string provided by Neon
DATABASE_URL=""

# Optional: adjust session lifetime (in days)
SESSION_TTL_DAYS=30
